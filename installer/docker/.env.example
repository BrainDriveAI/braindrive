# Required for production HTTPS
DOMAIN=app.example.com

# Image coordinates
BRAINDRIVE_TAG=latest
BRAINDRIVE_APP_IMAGE=ghcr.io/braindriveai/braindrive-app
BRAINDRIVE_EDGE_IMAGE=ghcr.io/braindriveai/braindrive-edge
# Optional Docker platform override for quickstart/prod image runs.
# Example for Apple Silicon when a tag/ref is amd64-only:
# BRAINDRIVE_DOCKER_PLATFORM=linux/amd64
BRAINDRIVE_DOCKER_PLATFORM=

# Optional immutable image references (recommended for production).
# If you set one, set both.
# Example:
# BRAINDRIVE_APP_REF=ghcr.io/braindrive-ai/braindrive-app@sha256:...
# BRAINDRIVE_EDGE_REF=ghcr.io/braindrive-ai/braindrive-edge@sha256:...
BRAINDRIVE_APP_REF=
BRAINDRIVE_EDGE_REF=

# Optional manifest-driven release resolution for upgrades.
# If BRAINDRIVE_APP_REF/BRAINDRIVE_EDGE_REF are unset, upgrade scripts can resolve
# digest refs from manifest metadata using the selected channel/version.
# Local metadata cache paths (used by upgrade scripts):
BRAINDRIVE_RELEASE_MANIFEST=./release-cache/releases.json
BRAINDRIVE_RELEASE_MANIFEST_SIG=./release-cache/releases.json.sig
BRAINDRIVE_RELEASE_PUBLIC_KEY=./release-cache/cosign.pub
# Remote metadata sources (optional, recommended for no-manual-env updates):
BRAINDRIVE_RELEASE_MANIFEST_URL=https://github.com/BrainDriveAI/BrainDrive/releases/latest/download/releases.json
BRAINDRIVE_RELEASE_MANIFEST_SIG_URL=https://github.com/BrainDriveAI/BrainDrive/releases/latest/download/releases.json.sig
BRAINDRIVE_RELEASE_PUBLIC_KEY_URL=https://github.com/BrainDriveAI/BrainDrive/releases/latest/download/cosign.pub
BRAINDRIVE_RELEASE_CHANNEL=stable
BRAINDRIVE_RELEASE_VERSION=
BRAINDRIVE_REQUIRE_MANIFEST_SIGNATURE=true
# Auto-install cosign for signature verification when missing (recommended for non-technical users).
BRAINDRIVE_AUTO_INSTALL_COSIGN=true
# Optional cosign download controls:
# BRAINDRIVE_COSIGN_VERSION=latest
# BRAINDRIVE_COSIGN_BIN_DIR=
# BRAINDRIVE_COSIGN_BIN=

# Startup update policy (quickstart/prod start path).
# Resolution order is runtime env > persistent app-config.json > .env > defaults.
# Defaults are tuned for non-technical image users:
#   BRAINDRIVE_UPDATES_ENABLED=true
#   BRAINDRIVE_STARTUP_UPDATE_CHECK=true
#   BRAINDRIVE_UPDATES_POLICY=auto-apply
#   BRAINDRIVE_UPDATES_FAIL_MODE=fail-open
#   BRAINDRIVE_UPDATES_MIN_CHECK_INTERVAL_MINUTES=60
BRAINDRIVE_UPDATES_ENABLED=true
BRAINDRIVE_STARTUP_UPDATE_CHECK=true
BRAINDRIVE_UPDATES_POLICY=auto-apply
BRAINDRIVE_UPDATES_FAIL_MODE=fail-open
BRAINDRIVE_UPDATES_MIN_CHECK_INTERVAL_MINUTES=60

# Optional windowed apply controls (used when BRAINDRIVE_UPDATES_POLICY=windowed-apply)
BRAINDRIVE_UPDATES_WINDOW_ENABLED=false
BRAINDRIVE_UPDATES_WINDOW_TIMEZONE=America/New_York
BRAINDRIVE_UPDATES_WINDOW_DAYS=Monday
BRAINDRIVE_UPDATES_WINDOW_START=13:00
BRAINDRIVE_UPDATES_WINDOW_END=18:00

# Required for encrypted secrets at runtime
PAA_SECRETS_MASTER_KEY_B64=
PAA_SECRETS_MASTER_KEY_ID=owner-master-v1

# Optional hardening / behavior
PAA_AUTH_BOOTSTRAP_TOKEN=
PAA_AUTH_ALLOW_FIRST_SIGNUP_ANY_IP=true
# Audit JSONL persistence under /data/memory/diagnostics/audit (Option B)
PAA_AUDIT_FILE_SINK_ENABLED=true
PAA_AUDIT_MAX_FILE_BYTES=5242880
PAA_AUDIT_RETENTION_DAYS=14
TZ=UTC

# Local-mode HTTP bind host (127.0.0.1 = this machine only, 0.0.0.0 = LAN)
BRAINDRIVE_LOCAL_BIND_HOST=127.0.0.1

# Developer hot-reload mode (compose.dev.yml)
# URL: http://<BRAINDRIVE_DEV_BIND_HOST>:<BRAINDRIVE_DEV_PORT>
BRAINDRIVE_DEV_BIND_HOST=127.0.0.1
BRAINDRIVE_DEV_PORT=5073
# Use polling if file watching is unreliable in your environment (WSL/network mounts)
BRAINDRIVE_DEV_CHOKIDAR_POLLING=false
BRAINDRIVE_DEV_CHOKIDAR_INTERVAL=250
BRAINDRIVE_DEV_WATCHPACK_POLLING=false
BRAINDRIVE_DEV_WATCHPACK_POLLING_INTERVAL=250
